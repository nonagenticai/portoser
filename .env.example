# ============================================================================
# Portoser Configuration
# ----------------------------------------------------------------------------
# Copy this file to `.env` and edit values for your environment.
# Multi-host scripts also need a `cluster.conf` (see cluster.conf.example).
#
# The variables in the "Path 1 — single-machine demo" block below are the only
# ones the root `docker-compose.yml` reads. Everything else applies to Path 2
# (multi-host scripts) and Path 3 (full backend / production stack).
# ============================================================================

# ----------------------------------------------------------------------------
# Path 1 — Single-machine demo (root docker-compose.yml)
# ----------------------------------------------------------------------------
# Host port the demo dashboard / Caddy front-end binds to.
PORTOSER_DEMO_PORT=8080

# ----------------------------------------------------------------------------
# Default machine
# ----------------------------------------------------------------------------
# Logical name of the machine commands target when no host is specified.
# Use "local" for single-host setups; otherwise pick a key from cluster.conf.
DEFAULT_MACHINE=local

# ----------------------------------------------------------------------------
# Paths (optional overrides)
# ----------------------------------------------------------------------------
# By default portoser locates everything relative to the script:
#   CADDY_REGISTRY_PATH = $SCRIPT_DIR/registry.yml
#   SERVICES_ROOT       = $(dirname $SCRIPT_DIR)
#   CADDYFILE_PATH      = $(dirname $SCRIPT_DIR)/caddy/Caddyfile
#   PIDS_DIR            = $(dirname $SCRIPT_DIR)/.pids
#
# Uncomment and set these only if your services live somewhere other than the
# repo (typical "production" layout where the repo is an admin tool and the
# registry + service trees live under $HOME/portoser).
# SERVICES_ROOT=${HOME}/portoser
# CADDY_REGISTRY_PATH=${HOME}/portoser/registry.yml
# CADDYFILE_PATH=${HOME}/portoser/caddy/Caddyfile
# PIDS_DIR=${HOME}/portoser/.pids
# LOGS_DIR=${HOME}/portoser/.logs

# ----------------------------------------------------------------------------
# Caddy admin API
# ----------------------------------------------------------------------------
# Endpoint of the Caddy admin API (used to push config reloads).
CADDY_ADMIN_API=http://127.0.0.1:2019

# ----------------------------------------------------------------------------
# Portoser HTTP API (optional)
# ----------------------------------------------------------------------------
# Bind host/port for the optional portoser API service.
PORTOSER_API_HOST=0.0.0.0
PORTOSER_API_PORT=8700

# ----------------------------------------------------------------------------
# SSH (used by multi-host scripts)
# ----------------------------------------------------------------------------
# Default SSH user when CLUSTER_HOSTS in cluster.conf does not specify one.
SSH_USER=${USER}
# Private key used for cluster SSH operations.
SSH_KEY_PATH=${HOME}/.ssh/id_rsa

# ----------------------------------------------------------------------------
# Docker
# ----------------------------------------------------------------------------
# Shared Docker network name created/expected by service compose files.
DOCKER_NETWORK=workflow-system-network

# ----------------------------------------------------------------------------
# Container registry (optional, for pushed images)
# ----------------------------------------------------------------------------
# Hostname[:port] of your image registry. Leave empty to skip pushes.
REGISTRY_HOST=
# Credentials (only needed if your registry requires auth).
REGISTRY_USER=
REGISTRY_PASSWORD=

# ----------------------------------------------------------------------------
# PostgreSQL
# ----------------------------------------------------------------------------
# Hostname for the cluster PostgreSQL instance (or PgBouncer in front of it).
POSTGRES_HOST=localhost
# TCP port for PostgreSQL / PgBouncer.
POSTGRES_PORT=5432
# Superuser used by maintenance scripts (e.g. password sync).
POSTGRES_SUPERUSER=postgres

# ----------------------------------------------------------------------------
# Keycloak
# ----------------------------------------------------------------------------
# Base URL of your Keycloak deployment (no trailing slash).
KEYCLOAK_URL=https://keycloak.example.local
# Realm used for service authentication.
KEYCLOAK_REALM=secure-apps
# Optional: path to the CA certificate trusted by clients calling Keycloak.
KEYCLOAK_CERT_PATH=

# ----------------------------------------------------------------------------
# Health checks
# ----------------------------------------------------------------------------
# Per-request timeout (seconds) for service health probes.
HEALTH_CHECK_TIMEOUT=30
# Polling interval (seconds) between health probes.
HEALTH_CHECK_INTERVAL=2

# ----------------------------------------------------------------------------
# Debug
# ----------------------------------------------------------------------------
# Set to 1 to enable verbose script output.
DEBUG=0
