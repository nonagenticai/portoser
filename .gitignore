# Environment configuration
.env
.env.*
!.env.example
!.env.template

# Local cluster topology (sensitive: contains user@host info)
cluster.conf

# Local copies of the example registries (user-edited from *.example.yml)
registry.yml
registry_v3.yml
registry_extended.yml
service_distribution.yml

# Runtime registry lock files written by the backend (fcntl flock targets).
# Created by routers/devices.py and services/device_health_monitor.py at
# runtime; never source-controlled.
*.yml.lock

# Logs
*.log
.logs/
logs/

# PID files
.pids/

# Temporary files
*.tmp
*.temp
/tmp/

# Backup files
*.backup
*.backup.*
*.bak
*.old
*.orig
*~
*.dump
Caddyfile.backup*

# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.pyo
.Python
.venv/
venv/
ENV/
env/
.pytest_cache/

# Docker
*.tar
docker-compose*.yml.bak
docker-compose*.yml.backup

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# (Previously `test_*.sh` was here, which silently ignored the entire
# bash test framework under tests/. Removed — keep test_* files tracked.)

# Certificate Files
*.pem
*.key
*.crt
*.p12
*.pfx
*.csr

# Database Files
*.db
*.sqlite
*.sqlite3
*.dump
*.sql

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Frontend build artifacts
web/frontend/dist/
dist/

# QA / test reports (developer-local)
qa-reports/

# Claude Code local settings (per-machine, may contain personal hostnames)
.claude/settings.local.json
# Claude Code scheduled-tasks lock (runtime fcntl target)
.claude/scheduled_tasks.lock
