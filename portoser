# Show help for repos command
show_repos_help() {
    cat <<EOF
Usage: portoser repos <subcommand> [options]

Repository management and version control operations.

Subcommands:
  commit <message>       Commit changes to repositories
                         Options:
                           --push     Push to remote after commit
                           --dry-run  Show what would happen

  status                 Show status of all repositories
                         Options:
                           --all      Show detailed output for all repos

  help                   Show this help message

