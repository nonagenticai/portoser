            else
                # Remote execution
                local ssh_user=$(get_machine_ssh_user "$machine")
                local machine_ip=$(get_machine_ip "$machine")

                # Source the scripts remotely and execute
                metrics=$(ssh -o ConnectTimeout=5 "$ssh_user@$machine_ip" "
                    source ~/.portoser_lib/platform/detector.sh 2>/dev/null || true
                    source ~/.portoser_lib/metrics/collector.sh 2>/dev/null || true
                    source ~/.portoser_lib/metrics/docker_stats.sh 2>/dev/null || true
                    get_service_resources '$service' '$machine' 2>/dev/null || echo '{\"error\":\"metrics_unavailable\"}'
                " 2>/dev/null)
            fi

            # Check if metrics are unavailable due to missing libs
            if echo "$metrics" | jq -e '.error == "metrics_unavailable"' >/dev/null 2>&1; then
                echo "Error: Metrics are unavailable on machine '$machine'" >&2
                echo "" >&2
                echo "The remote machine may not be bootstrapped with portoser libraries." >&2
                echo "Please run: portoser remote bootstrap $machine" >&2
                echo "" >&2
                exit 1
            fi

            if [ $json_mode -eq 1 ]; then
                echo "$metrics"
            else
                echo "Resource Metrics for $service on $machine:"
                echo "$metrics" | jq -C '.' 2>/dev/null || echo "$metrics"
            fi
            ;;
        machine)
            if [ $# -eq 0 ]; then
                echo "Error: Machine name required"
                echo "Usage: portoser metrics machine MACHINE [--json-output]"
                exit 1
            fi

            local machine="$1"
            shift

            # Check for JSON output flag
            local json_mode=0
            for arg in "$@"; do
                [ "$arg" = "--json-output" ] && json_mode=1
            done

            # Get machine metrics
            local metrics
            if [ "$machine" = "local" ] || [ "$machine" = "m1" ]; then
                metrics=$(get_system_metrics_json)
            else
                # Remote execution
                local ssh_user=$(get_machine_ssh_user "$machine")
                local machine_ip=$(get_machine_ip "$machine")

                metrics=$(ssh -o ConnectTimeout=5 "$ssh_user@$machine_ip" "
                    source ~/.portoser_lib/platform/detector.sh 2>/dev/null || true
                    source ~/.portoser_lib/metrics/collector.sh 2>/dev/null || true
                    get_system_metrics_json 2>/dev/null || echo '{\"error\":\"metrics_unavailable\"}'
                " 2>/dev/null)
            fi

            # Check if metrics are unavailable due to missing libs
            if echo "$metrics" | jq -e '.error == "metrics_unavailable"' >/dev/null 2>&1; then
                echo "Error: Metrics are unavailable on machine '$machine'" >&2
                echo "" >&2
                echo "The remote machine may not be bootstrapped with portoser libraries." >&2
                echo "Please run: portoser remote bootstrap $machine" >&2
                echo "" >&2
                exit 1
            fi

            if [ $json_mode -eq 1 ]; then
                echo "$metrics"
            else
                echo "System Metrics for $machine:"
                echo "$metrics" | jq -C '.' 2>/dev/null || echo "$metrics"
            fi
            ;;
        all)
            # Check for JSON output flag
            local json_mode=0
            for arg in "$@"; do
                [ "$arg" = "--json-output" ] && json_mode=1
            done

            if [ $json_mode -eq 1 ]; then
                echo '{"machines":['
            else
                echo "Collecting metrics from all machines..."
                echo ""
            fi

            local machines=($(list_machines | tail -n +2))
            local first=true

            for machine in "${machines[@]}"; do
                local metrics
                if [ "$machine" = "local" ] || [ "$machine" = "m1" ]; then
                    metrics=$(get_system_metrics_json)
                else
                    local ssh_user=$(get_machine_ssh_user "$machine")
                    local machine_ip=$(get_machine_ip "$machine")

                    metrics=$(ssh -o ConnectTimeout=5 "$ssh_user@$machine_ip" "
                        source ~/.portoser_lib/platform/detector.sh 2>/dev/null || true
                        source ~/.portoser_lib/metrics/collector.sh 2>/dev/null || true
                        get_system_metrics_json 2>/dev/null || echo '{\"error\":\"metrics_unavailable\"}'
                    " 2>/dev/null)
                fi

                if [ $json_mode -eq 1 ]; then
                    [ "$first" = false ] && echo ","
                    first=false
                    echo "{\"machine\":\"$machine\",\"metrics\":$metrics}"
                else
                    echo "=== $machine ==="
                    echo "$metrics" | jq -C '.' 2>/dev/null || echo "$metrics"
                    echo ""
                fi
            done

            if [ $json_mode -eq 1 ]; then
                echo ']}'
            fi
            ;;
        test)
            # Run compatibility test
            bash "$SCRIPT_DIR/lib/metrics/test_compatibility.sh"
            ;;
        *)
            print_color "$RED" "Unknown metrics subcommand: $subcommand"
            echo "Run 'portoser metrics' for usage"
            exit 1
            ;;
    esac
}

# Uptime command handler
cmd_uptime() {
    if [ $# -eq 0 ]; then
        cat <<EOF
Usage: portoser uptime <subcommand> [options]

Service uptime tracking and statistics.

Subcommands:
  service SERVICE MACHINE [--json-output]
                             Get uptime statistics for a service
  all [--json-output]        Get uptime for all services
  history SERVICE MACHINE [--days N] [--json-output]
                             Get uptime history (start/stop/failure events)
  status SERVICE MACHINE     Get current service status (running/stopped)

Examples:
  portoser uptime service requirements mini2
  portoser uptime all --json-output
  portoser uptime history requirements mini2 --days 7
  portoser uptime status requirements mini2
EOF
        exit 0
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        -h|--help)
            cmd_uptime
            ;;
        service)
            if [ $# -lt 2 ]; then
                echo "Error: Service and machine names required"
                echo "Usage: portoser uptime service SERVICE MACHINE [--json-output]"
                exit 1
            fi

            local service="$1"
            local machine="$2"
            shift 2

            # Check for JSON output flag
            local json_mode=0
            for arg in "$@"; do
                [ "$arg" = "--json-output" ] && json_mode=1
            done

            # Get uptime stats
            local stats=$(get_uptime_stats_json "$service" "$machine")

            if [ $json_mode -eq 1 ]; then
                echo "$stats"
            else
                echo "Uptime Statistics for $service on $machine:"
                echo "$stats" | jq -C '.' 2>/dev/null || echo "$stats"
            fi
            ;;
        all)
            # Check for JSON output flag
            local json_mode=0
            for arg in "$@"; do
                [ "$arg" = "--json-output" ] && json_mode=1
            done

            if [ $json_mode -eq 1 ]; then
                echo '{"services":['
            else
                echo "Uptime Statistics for All Services:"
                echo ""
            fi

            # Get all services
            local services=($(list_services | tail -n +2))
            local first=true

            for service in "${services[@]}"; do
                local machine=$(get_service_host "$service" 2>/dev/null)
                if [ -n "$machine" ] && [ "$machine" != "null" ]; then
                    local stats=$(get_uptime_stats_json "$service" "$machine")

                    if [ $json_mode -eq 1 ]; then
                        [ "$first" = false ] && echo ","
                        first=false
                        echo "$stats"
                    else
                        echo "=== $service on $machine ==="
                        echo "$stats" | jq -C '.' 2>/dev/null || echo "$stats"
                        echo ""
                    fi
                fi
            done

            if [ $json_mode -eq 1 ]; then
                echo ']}'
            fi
            ;;
        history)
            if [ $# -lt 2 ]; then
                echo "Error: Service and machine names required"
                echo "Usage: portoser uptime history SERVICE MACHINE [--days N] [--json-output]"
                exit 1
            fi

            local service="$1"
            local machine="$2"
            shift 2

            # Parse options
            local days=7
            local json_mode=0

            while [ $# -gt 0 ]; do
                case "$1" in
                    --days)
                        days="$2"
                        shift 2
                        ;;
                    --json-output)
                        json_mode=1
                        shift
                        ;;
                    *)
                        shift
                        ;;
                esac
            done

            # Get uptime history
            local history=$(get_uptime_history "$service" "$machine" "$days")

            if [ $json_mode -eq 1 ]; then
                echo "$history"
            else
                echo "Uptime History for $service on $machine (last $days days):"
                echo "$history" | jq -C '.' 2>/dev/null || echo "$history"
            fi
            ;;
        status)
            if [ $# -lt 2 ]; then
                echo "Error: Service and machine names required"
                echo "Usage: portoser uptime status SERVICE MACHINE"
                exit 1
            fi

            local service="$1"
            local machine="$2"

            local service_status=$(get_service_uptime_status "$service" "$machine")
            echo "Service Status: $service_status"
            ;;
        *)
            print_color "$RED" "Unknown uptime subcommand: $subcommand"
            echo "Run 'portoser uptime' for usage"
            exit 1
            ;;
    esac
}

# Cluster command handler
cmd_cluster() {
    if [ $# -eq 0 ]; then
        cat <<EOF
Usage: portoser cluster <subcommand> [options]

Raspberry Pi cluster management commands.

Subcommands:
  build [--all|SERVICE] [--rebuild] [--batch-size N]
                             Build Docker images for cluster services
                             --all: Build all Pi services
                             --rebuild: Force rebuild with --no-cache
                             --batch-size N: Number of parallel builds (default: 4)

  deploy [--all|--pi PI] [SERVICE...]
                             Deploy services to Pi cluster nodes
                             --all: Deploy to all Pis
                             --pi PI: Target specific Pi (pi1-pi4)

  sync [PI...] [--dry-run]   Sync Pi directories to local Documents folder
                             --dry-run: Show what would be synced

  clean [PI...] [--dry-run]  Clean Pi nodes to keep only runtime essentials
                             --dry-run: Show what would be deleted

  health [--watch] [--no-ssl]
                             Check health of all cluster services
                             --watch: Continuously monitor health
                             --no-ssl: Disable SSL verification

  docker-health [--no-delay] [--verbose]
                             Count healthy Docker containers across cluster
                             --no-delay: Skip initial 25s delay
                             --verbose: Show detailed container info

  setup-buildx               Configure Docker buildx for multi-platform builds

  scan [PI...]               Scan cluster nodes for services

  status [--json]            Show status of all cluster services
                             --json: Output in JSON format

Global Flags:
  --json                     Output in JSON format (available for most commands)
  --verbose                  Enable verbose output
  --quiet                    Suppress non-error output

Examples:
  # Build all services
  portoser cluster build --all

  # Build specific service with rebuild
  portoser cluster build kag --rebuild

  # Deploy to specific Pi
  portoser cluster deploy --pi pi1 kag workers

  # Deploy to all Pis
  portoser cluster deploy --all

  # Sync all Pis
  portoser cluster sync

  # Sync specific Pis (dry run)
  portoser cluster sync pi1 pi3 --dry-run

  # Clean Pis (dry run)
  portoser cluster clean --dry-run

  # Check cluster health
  portoser cluster health

  # Check Docker container health across cluster
  portoser cluster docker-health --no-delay --verbose

  # Setup buildx builder
  portoser cluster setup-buildx

  # Scan for services
  portoser cluster scan

  # Get cluster status
  portoser cluster status --json
EOF
        exit 0
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        -h|--help)
            cmd_cluster
            ;;
        build)
            # Parse arguments
            local build_all=false
            local rebuild=false
            local batch_size=4
            local services=()
            local json_mode=false
            local verbose=false
            local quiet=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --all)
                        build_all=true
                        shift
                        ;;
                    --rebuild)
                        rebuild=true
                        shift
                        ;;
                    --batch-size)
                        batch_size="$2"
                        shift 2
                        ;;
                    --json)
                        json_mode=true
                        shift
                        ;;
                    --verbose)
                        verbose=true
                        shift
                        ;;
                    --quiet)
                        quiet=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        services+=("$1")
                        shift
                        ;;
                esac
            done

            # Validate parameters
            if [ "$build_all" = false ] && [ ${#services[@]} -eq 0 ]; then
                print_color "$RED" "Error: Must specify --all or one or more service names"
                echo "Usage: portoser cluster build [--all|SERVICE] [--rebuild] [--batch-size N]"
                exit 1
            fi

            # Get service list
            local service_list=""
            if [ "$build_all" = true ]; then
                # Get all Pi services from registry
                service_list=$(yq eval '.services[] | select(.tags[] == "pi") | .name' "$CADDY_REGISTRY_PATH" 2>/dev/null | tr '\n' ' ')
            else
                service_list="${services[*]}"
            fi

            if [ -z "$service_list" ]; then
                print_color "$YELLOW" "Warning: No services to build"
                exit 0
            fi

            # Build services
            print_color "$BLUE" "Building services: $service_list"
            [ "$rebuild" = true ] && print_color "$YELLOW" "  Force rebuild enabled (--no-cache)"
            print_color "$BLUE" "  Batch size: $batch_size"
            echo ""

            # Convert space-separated list to newline-separated for library function
            local services_newline=$(echo "$service_list" | tr ' ' '\n')

            # Call library function
            if build_services_parallel "$services_newline" "$CADDY_REGISTRY_PATH" "portoser-builder" "$batch_size" "$rebuild" "true"; then
                print_color "$GREEN" "Build completed successfully"
            else
                print_color "$RED" "Build failed"
                exit 1
            fi
            ;;
        deploy)
            # Parse arguments
            local deploy_all=false
            local target_pi=""
            local services=()
            local json_mode=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --all)
                        deploy_all=true
                        shift
                        ;;
                    --pi)
                        target_pi="$2"
                        shift 2
                        ;;
                    --json)
                        json_mode=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        services+=("$1")
                        shift
                        ;;
                esac
            done

            if [ "$deploy_all" = false ] && [ -z "$target_pi" ]; then
                print_color "$RED" "Error: Must specify --all or --pi PI"
                echo "Usage: portoser cluster deploy [--all|--pi PI] [SERVICE...]"
                exit 1
            fi

            # Deploy services
            if [ "$deploy_all" = true ]; then
                print_color "$BLUE" "Deploying to all Pis..."

                for pi in pi1 pi2 pi3 pi4; do
                    print_color "$BLUE" "Deploying to $pi..."
                    if [ ${#services[@]} -gt 0 ]; then
                        # Deploy specific services
                        for service in "${services[@]}"; do
                            local service_dir="${SYNC_BASE_DIR:-${HOME}/portoser-services}/$service"
                            if [ -d "$service_dir" ]; then
                                deploy_service_to_pi "$service" "$pi" "$service_dir" || true
                            else
                                print_color "$YELLOW" "Warning: Service directory not found: $service_dir"
                            fi
                        done
                    else
                        # Deploy all services for this Pi
                        deploy_to_pi "$pi" "$CADDY_REGISTRY_PATH" || true
                    fi
                    echo ""
                done

                print_color "$GREEN" "Deployment complete"
            else
                print_color "$BLUE" "Deploying to $target_pi..."

                if [ ${#services[@]} -gt 0 ]; then
                    # Deploy specific services
                    for service in "${services[@]}"; do
                        local service_dir="${SYNC_BASE_DIR:-${HOME}/portoser-services}/$service"
                        if [ -d "$service_dir" ]; then
                            deploy_service_to_pi "$service" "$target_pi" "$service_dir"
                        else
                            print_color "$RED" "Error: Service directory not found: $service_dir"
                            exit 1
                        fi
                    done
                else
                    # Deploy all services for this Pi
                    deploy_to_pi "$target_pi" "$CADDY_REGISTRY_PATH"
                fi

                print_color "$GREEN" "Deployment to $target_pi complete"
            fi
            ;;
        sync)
            # Parse arguments
            local pis=()
            local dry_run=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --dry-run)
                        dry_run=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        pis+=("$1")
                        shift
                        ;;
                esac
            done

            # Default to all Pis if none specified
            local pi_list="${pis[*]:-pi1 pi2 pi3 pi4}"

            print_color "$BLUE" "Syncing Pis: $pi_list"
            [ "$dry_run" = true ] && print_color "$YELLOW" "  DRY RUN MODE (no files will be synced)"
            echo ""

            # Call library function
            # Note: sync_all_pis uses "pull" direction by default
            if sync_all_pis "pull" "$pi_list" "${SYNC_BASE_DIR:-${HOME}/portoser-services}" "$dry_run"; then
                print_color "$GREEN" "Sync completed successfully"
            else
                print_color "$RED" "Sync failed"
                exit 1
            fi
            ;;
        clean)
            # Parse arguments
            local pis=()
            local dry_run=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --dry-run)
                        dry_run=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        pis+=("$1")
                        shift
                        ;;
                esac
            done

            # Default to all Pis if none specified
            local pi_list="${pis[*]:-pi1 pi2 pi3 pi4}"

            print_color "$BLUE" "Cleaning Pis: $pi_list"
            [ "$dry_run" = true ] && print_color "$YELLOW" "  DRY RUN MODE (no files will be deleted)"
            echo ""

            # Call the existing clean-pis.sh script
            local script_path="$SCRIPT_DIR/scripts/clean-pis.sh"
            if [ -f "$script_path" ]; then
                local args=()
                [ "$dry_run" = true ] && args+=("--dry-run")
                [ -n "$pi_list" ] && args+=($pi_list)

                "$script_path" "${args[@]}"
            else
                print_color "$RED" "Error: clean-pis.sh script not found at $script_path"
                exit 1
            fi
            ;;
        health)
            # Parse arguments
            local watch=false
            local no_ssl=false
            local json_mode=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --watch)
                        watch=true
                        shift
                        ;;
                    --no-ssl)
                        no_ssl=true
                        shift
                        ;;
                    --json)
                        json_mode=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Unknown argument: $1"
                        exit 1
                        ;;
                esac
            done

            # Call library function or script
            local script_path="$SCRIPT_DIR/scripts/check-all-health.sh"
            if [ -f "$script_path" ]; then
                local args=()
                [ "$no_ssl" = true ] && args+=("--no-ssl")
                [ "$watch" = false ] && args+=("--quiet") || true

                if [ "$watch" = true ]; then
                    print_color "$BLUE" "Monitoring cluster health (Ctrl+C to stop)..."
                    while true; do
                        clear
                        "$script_path" "${args[@]}"
                        sleep 5
                    done
                else
                    "$script_path" "${args[@]}"
                fi
            else
                print_color "$RED" "Error: check-all-health.sh script not found at $script_path"
                exit 1
            fi
            ;;
        docker-health)
            # Parse arguments
            local no_delay=false
            local verbose=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    -h|--help)
                        cat <<EOF
Usage: portoser cluster docker-health [OPTIONS]

Count healthy Docker containers across the entire cluster (MINI1, PI1-3).

Options:
  --no-delay      Skip initial 25-second delay
  --verbose       Show detailed container information
  -h, --help      Show this help message

Example:
  portoser cluster docker-health --no-delay --verbose
EOF
                        exit 0
                        ;;
                    --no-delay)
                        no_delay=true
                        shift
                        ;;
                    --verbose)
                        verbose=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Unknown argument: $1"
                        exit 1
                        ;;
                esac
            done

            # Call script
            local script_path="$SCRIPT_DIR/scripts/check-cluster-docker-health.sh"
            if [ -f "$script_path" ]; then
                local args=()
                [ "$no_delay" = true ] && args+=("--no-delay")
                [ "$verbose" = true ] && args+=("--verbose")

                "$script_path" "${args[@]}"
            else
                print_color "$RED" "Error: check-cluster-docker-health.sh script not found at $script_path"
                exit 1
            fi
            ;;
        setup-buildx)
            print_color "$BLUE" "Setting up Docker buildx for cluster..."
            echo ""

            # Call library function
            if setup_cluster_buildx "$CADDY_REGISTRY_PATH"; then
                print_color "$GREEN" "Buildx setup completed successfully"
            else
                print_color "$RED" "Buildx setup failed"
                exit 1
            fi
            ;;
        scan)
            # Parse arguments
            local pis=()
            local json_mode=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --json)
                        json_mode=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        pis+=("$1")
                        shift
                        ;;
                esac
            done

            # Default to all Pis if none specified
            local pi_list="${pis[*]:-pi1 pi2 pi3 pi4}"

            print_color "$BLUE" "Scanning Pis for services: $pi_list"
            echo ""

            # Call library function
            if [ "$json_mode" = true ]; then
                discover_all_services "$pi_list" | jq '.'
            else
                discover_all_services "$pi_list"
            fi
            ;;
        status)
            # Parse arguments
            local json_mode=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --json)
                        json_mode=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Unknown option: $1"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Unknown argument: $1"
                        exit 1
                        ;;
                esac
            done

            print_color "$BLUE" "Getting cluster status..."
            echo ""

            # Resolve registry path the same way the rest of the CLI does:
            # honour CADDY_REGISTRY_PATH if set, otherwise fall back to
            # the canonical install location.
            local registry_path="${CADDY_REGISTRY_PATH:-/etc/portoser/registry.yml}"

            # Call library function
            if [ "$json_mode" = true ]; then
                check_cluster_health "$registry_path" true json | jq '.'
            else
                check_cluster_health "$registry_path" true text
            fi
            ;;
        *)
            print_color "$RED" "Unknown cluster subcommand: $subcommand"
            echo "Run 'portoser cluster' for usage"
            exit 1
            ;;
    esac
}

################################################################################
# cmd_databases() - Database Management Command
#
# This function provides database management capabilities for the portoser CLI.
# It handles switching between test and production database modes, checking
# status, syncing databases, and setting up test environments.
#
# Usage:
#   portoser databases switch <prod|test|status>
#   portoser databases status [--json-output]
#   portoser databases sync [--source SRC] [--target TGT] [--dry-run]
#   portoser databases setup-test [--host MACHINE]
#   portoser databases help
################################################################################

# Help function for databases command
show_databases_help() {
    cat <<EOF
Usage: portoser databases <subcommand> [options]

Manage database environments and switching between test and production modes.

SUBCOMMANDS:

  switch <mode>
      Switch between database environments

      Modes:
        prod        Switch to production database (mini2)
        test        Switch to test database (mini1)
        status      Show current database mode without switching

      Examples:
        portoser databases switch prod
        portoser databases switch test
        portoser databases switch status

  status [--json-output]
      Display current database environment status

      Options:
        --json-output    Output status in JSON format

      Examples:
        portoser databases status
        portoser databases status --json-output

  sync [--source SRC] [--target TGT] [--dry-run]
      Sync databases between environments

      Options:
        --source SRC     Source database server (default: production)
        --target TGT     Target database server (default: test)
        --dry-run        Show what would be copied without executing

      Examples:
        portoser databases sync
        portoser databases sync --dry-run
        portoser databases sync --source mini1 --target mini2

  setup-test [--host MACHINE]
      Setup test database environment on specified host

      Options:
        --host MACHINE   Target machine for test setup (default: mini2)

      Examples:
        portoser databases setup-test
        portoser databases setup-test --host mini2

  help
      Show this help message

DESCRIPTION:

  The databases command manages switching between production and test database
  environments. This includes PostgreSQL and Neo4j instances.

  Production Mode: Uses the host configured as the production database server
                   in registry.yml / cluster.conf (look for the prod_db host).
  Test Mode:       Uses the host configured as the test database server.

  When switching modes, the system:
    1. Updates DNS configuration (dnsmasq or /etc/hosts)
    2. Syncs PgBouncer configuration to target server
    3. Ensures PgBouncer is running on target server
    4. Verifies the switch was successful

EXAMPLES:

  # Check current database mode
  portoser databases status

  # Switch to test environment
  portoser databases switch test

  # Switch to production environment
  portoser databases switch prod

  # Sync production data to test
  portoser databases sync --dry-run
  portoser databases sync

  # Setup test environment on mini2
  portoser databases setup-test

EOF
}

# Main databases command function
cmd_databases() {
    local subcommand="${1:-}"
    shift || true

    case "$subcommand" in
        switch)
            # Parse mode argument
            local mode="${1:-status}"
            shift || true

            # Validate mode
            case "$mode" in
                prod|production)
                    mode="production"
                    ;;
                test)
                    mode="test"
                    ;;
                status)
                    mode="status"
                    ;;
                *)
                    print_color "$RED" "Error: Invalid mode '$mode'"
                    echo "Valid modes: prod, test, status"
                    echo ""
                    echo "Usage: portoser databases switch <prod|test|status>"
                    exit 1
                    ;;
            esac

            # Call library function
            switch_database_mode "$mode"
            exit $?
            ;;

        status)
            # Parse arguments
            local json_output=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --json-output|--json)
                        json_output=true
                        shift
                        ;;
                    -*)
                        print_color "$RED" "Error: Unknown option: $1"
                        echo "Usage: portoser databases status [--json-output]"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Error: Unexpected argument: $1"
                        echo "Usage: portoser databases status [--json-output]"
                        exit 1
                        ;;
                esac
            done

            # Call library function
            if [ "$json_output" = true ]; then
                show_database_status --json
                exit $?
            else
                show_database_status
                exit $?
            fi
            ;;

        sync)
            # Parse arguments
            local source=""
            local target=""
            local dry_run=false

            while [ $# -gt 0 ]; do
                case "$1" in
                    --source)
                        if [ -z "${2:-}" ]; then
                            print_color "$RED" "Error: --source requires a value"
                            exit 1
                        fi
                        source="$2"
                        shift 2
                        ;;
                    --target)
                        if [ -z "${2:-}" ]; then
                            print_color "$RED" "Error: --target requires a value"
                            exit 1
                        fi
                        target="$2"
                        shift 2
                        ;;
                    --dry-run)
                        dry_run=true
                        shift
                        ;;
                    -h|--help)
                        echo "Usage: portoser databases sync [--source SRC] [--target TGT] [--dry-run]"
                        echo ""
                        echo "Sync databases between environments"
                        echo ""
                        echo "Options:"
                        echo "  --source SRC     Source database server (default: production)"
                        echo "  --target TGT     Target database server (default: test)"
                        echo "  --dry-run        Show what would be copied without executing"
                        exit 0
                        ;;
                    -*)
                        print_color "$RED" "Error: Unknown option: $1"
                        echo "Usage: portoser databases sync [--source SRC] [--target TGT] [--dry-run]"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Error: Unexpected argument: $1"
                        echo "Usage: portoser databases sync [--source SRC] [--target TGT] [--dry-run]"
                        exit 1
                        ;;
                esac
            done

            # Call library function
            sync_databases "$source" "$target" "$dry_run"
            exit $?
            ;;

        setup-test)
            # Parse arguments
            local target_host="mini2"

            while [ $# -gt 0 ]; do
                case "$1" in
                    --host)
                        if [ -z "${2:-}" ]; then
                            print_color "$RED" "Error: --host requires a value"
                            exit 1
                        fi
                        target_host="$2"
                        shift 2
                        ;;
                    -h|--help)
                        echo "Usage: portoser databases setup-test [--host MACHINE]"
                        echo ""
                        echo "Setup test database environment on specified host"
                        echo ""
                        echo "Options:"
                        echo "  --host MACHINE   Target machine for test setup (default: mini2)"
                        exit 0
                        ;;
                    -*)
                        print_color "$RED" "Error: Unknown option: $1"
                        echo "Usage: portoser databases setup-test [--host MACHINE]"
                        exit 1
                        ;;
                    *)
                        print_color "$RED" "Error: Unexpected argument: $1"
                        echo "Usage: portoser databases setup-test [--host MACHINE]"
                        exit 1
                        ;;
                esac
            done

            # Call library function
            setup_test_databases "$target_host"
            exit $?
            ;;

        -h|--help|help|"")
            show_databases_help
            exit 0
            ;;

        *)
            print_color "$RED" "Error: Unknown databases subcommand: $subcommand"
            echo ""
            show_databases_help
            exit 1
            ;;
    esac
}

################################################################################
# End of cmd_databases()
################################################################################

# Run main function
main "$@"
