# Perform git commit operations
perform_git_commit() {
    local message="$1"
    local push=0
    local dry_run=0

    shift

    # Parse flags
    for arg in "$@"; do
        case "$arg" in
            --push)
                push=1
                ;;
            --dry-run)
                dry_run=1
                ;;
        esac
    done

    if [ -z "$message" ]; then
        print_color "$RED" "Error: Commit message is required"
        exit 1
    fi

    local services_root="${SERVICES_ROOT:-$(dirname "$(cd -P "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)")}"

    if [ $dry_run -eq 1 ]; then
        print_color "$BLUE" "Dry-run: Would commit with message: '$message'"
        if [ $push -eq 1 ]; then
            print_color "$BLUE" "Dry-run: Would push to remote after commit"
        fi
        echo ""
        echo "Repositories that would be committed:"
        echo "  (Dry-run mode - no actual changes)"
        return 0
    fi

    print_color "$BLUE" "Committing changes across repositories..."
    echo "Message: $message"
    echo ""

    local commit_count=0
    local error_count=0

    # Find all .git directories (each represents a repository)
    while IFS= read -r git_dir; do
        if [ -d "$git_dir" ]; then
            local repo_path="$(dirname "$git_dir")"
            local repo_name="$(basename "$repo_path")"

            # Check if there are changes to commit
            if (cd "$repo_path" && git status --porcelain | grep -q .); then
                print_color "$YELLOW" "Repository: $repo_name"

                if (cd "$repo_path" && git add -A && git commit -m "$message"); then
                    print_color "$GREEN" "  ✓ Committed successfully"
                    ((commit_count++))

                    if [ $push -eq 1 ]; then
                        if (cd "$repo_path" && git push); then
                            print_color "$GREEN" "  ✓ Pushed to remote"
                        else
                            print_color "$RED" "  ✗ Failed to push"
                            ((error_count++))
                        fi
                    fi
                else
                    print_color "$RED" "  ✗ Commit failed"
                    ((error_count++))
                fi
            else
                print_color "$BLUE" "Repository: $repo_name"
                print_color "$BLUE" "  (no changes)"
            fi
            echo ""
        fi
    done < <(find "$services_root" -type d -name ".git" 2>/dev/null)

    # Summary
    print_color "$BLUE" "=== Commit Summary ==="
    print_color "$GREEN" "Committed: $commit_count repositories"
    if [ $error_count -gt 0 ]; then
        print_color "$RED" "Errors: $error_count"
        return 1
    fi
    return 0
}

# Show repository status
show_repos_status() {
    local show_all=0

    # Parse flags
    for arg in "$@"; do
        case "$arg" in
            --all)
                show_all=1
                ;;
        esac
    done

    local services_root="${SERVICES_ROOT:-$(dirname "$(cd -P "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)")}"

    print_color "$BLUE" "=== Repository Status ==="
    echo ""

    local total_repos=0
    local clean_repos=0
    local dirty_repos=0

    # Find all .git directories
    while IFS= read -r git_dir; do
        if [ -d "$git_dir" ]; then
            local repo_path="$(dirname "$git_dir")"
            local repo_name="$(basename "$repo_path")"
            local status_output
            local is_clean=0

            ((total_repos++))

            # Check repository status
            status_output=$(cd "$repo_path" && git status --porcelain)

            if [ -z "$status_output" ]; then
                is_clean=1
                ((clean_repos++))
                print_color "$GREEN" "✓ $repo_name"
                print_color "$GREEN" "  Status: Clean"
            else
                ((dirty_repos++))
                print_color "$YELLOW" "⚠ $repo_name"
                print_color "$YELLOW" "  Status: Changes detected"

                if [ $show_all -eq 1 ]; then
                    echo "  Changes:"
                    echo "$status_output" | sed 's/^/    /'
                fi
            fi

            # Show current branch if --all
            if [ $show_all -eq 1 ]; then
                local branch
                branch=$(cd "$repo_path" && git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
                print_color "$BLUE" "  Branch: $branch"
            fi

            echo ""
        fi
    done < <(find "$services_root" -type d -name ".git" 2>/dev/null)

    # Summary
    print_color "$BLUE" "=== Status Summary ==="
    echo "Total repositories: $total_repos"
    print_color "$GREEN" "Clean: $clean_repos"
    print_color "$YELLOW" "With changes: $dirty_repos"
    echo ""

    if [ $dirty_repos -gt 0 ]; then
        echo "Use 'portoser repos commit <message>' to commit changes"
        echo "Use 'portoser repos status --all' for detailed view"
        return 1
    fi
    return 0
}

# Main repos command handler
cmd_repos() {
    if [ $# -eq 0 ]; then
