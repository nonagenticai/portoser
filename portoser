# Status command handler
cmd_status() {
    echo "Portoser - Service Status Overview"
    echo "======================================"
    echo ""

    local services=$(list_services)

    printf "%-25s %-10s %-15s %-10s %s\n" "SERVICE" "TYPE" "MACHINE" "STATUS" "HEALTH"
    echo "--------------------------------------------------------------------------------"

    # Use file descriptor 3 for reading services to free stdin for SSH commands
    while IFS= read -r -u 3 service; do
        if [ -z "$service" ]; then
            continue
        fi

        local service_type=$(get_service_type "$service")
        local current_host=$(get_service_host "$service")
        local service_status=$(get_service_status "$service" 2>/dev/null || echo "unknown")
        local health="N/A"

        if [ "$service_status" = "running" ]; then
            if check_service_health "$service" 1 2>/dev/null; then
                health="✓"
            else
                health="✗"
            fi
        fi

        printf "%-25s %-10s %-15s %-10s %s\n" "$service" "$service_type" "$current_host" "$service_status" "$health"
    done 3<<< "$services"

    echo ""
}

# Diagnose command handler - Troubleshoot service issues
cmd_diagnose() {
    if [ $# -eq 0 ]; then
        echo "Usage: portoser diagnose <service> [machine] [OPTIONS]"
        echo ""
        echo "Diagnose issues with a service deployment."
        echo "Uses Toyota Engagement Equation: Go to See → Grasp the Situation"
        echo ""
        echo "Options:"
        echo "  --json-output    Output structured JSON instead of colored text"
        echo ""
        echo "Example:"
        echo "  portoser diagnose requirements mini2"
        echo "  portoser diagnose requirements mini2 --json-output"
        exit 1
    fi

    local service="${1:-}"
    local machine="${2:-}"

    # Check for --json-output flag
    if [ "${2:-}" = "--json-output" ] || [ "${3:-}" = "--json-output" ]; then
        export JSON_OUTPUT_MODE=1
        if [ "${2:-}" = "--json-output" ]; then
            machine="$(get_service_host "$service" 2>/dev/null)"
        fi
    fi

    # If machine not provided and not from flag parsing
    if [ -z "$machine" ] || [ "$machine" = "--json-output" ]; then
        machine="$(get_service_host "$service" 2>/dev/null)"
    fi

    if [ -z "$machine" ] || [ "$machine" = "null" ]; then
        if is_json_output_mode; then
            echo '{"error": "Service not deployed", "service": "'$service'"}'
        else
            print_color "$RED" "Error: Service '$service' is not deployed"
            echo "Specify target machine: portoser diagnose $service MACHINE"
        fi
        exit 1
    fi

    # Initialize JSON output if enabled
    if is_json_output_mode; then
        init_json_diagnose_output
        JSON_DIAGNOSE_DATA[service]="$service"
        JSON_DIAGNOSE_DATA[machine]="$machine"
    fi

    json_print_color "$BLUE" "🔍 DIAGNOSTIC MODE"
    json_print ""
    json_print_color "$BLUE" "Service: $service"
    json_print_color "$BLUE" "Machine: $machine"
    json_print ""
    json_print "================================================================"
    json_print ""

    # Clear previous state
    OBSERVATION_RESULTS=()
    IDENTIFIED_PROBLEMS=()
    ROOT_CAUSES=()

    # GO TO SEE — observe phase returns non-zero when issues are found, but
    # finding issues is precisely what diagnose is for. Don't let set -e
    # short-circuit the rest of the diagnostic flow.
    observe_deployment_readiness "$service" "$machine" || true

    # Collect observations for JSON
    if is_json_output_mode; then
        for obs_key in "${!OBSERVATION_RESULTS[@]}"; do
            local obs_data="${OBSERVATION_RESULTS[$obs_key]}"
            local status="${obs_data%%|*}"
            local rest="${obs_data#*|}"
            local value="${rest%%|*}"
            local message="${rest#*|}"
            json_add_observation "$obs_key" "$status" "$message"
        done
    fi

    json_print ""
    json_print "================================================================"
    json_print ""

    # GRASP THE SITUATION — same set -e caveat as observe.
    diagnose_deployment_issues "$service" "$machine" || true

    # Collect problems for JSON
    if is_json_output_mode; then
        for fingerprint in "${!IDENTIFIED_PROBLEMS[@]}"; do
            local problem_data="${IDENTIFIED_PROBLEMS[$fingerprint]}"
            local root_cause="${ROOT_CAUSES[$fingerprint]}"
            local severity="high"

            # Determine severity based on fingerprint
            case "$fingerprint" in
                PROBLEM_SSH_CONNECTION_FAILED|PROBLEM_DOCKER_NOT_RUNNING)
                    severity="critical"
                    ;;
                PROBLEM_DEPENDENCY_UNHEALTHY|PROBLEM_PORT_CONFLICT)
                    severity="high"
                    ;;
                PROBLEM_DISK_SPACE_LOW|PROBLEM_STALE_PROCESS)
                    severity="medium"
                    ;;
                *)
                    severity="low"
                    ;;
            esac

            json_add_problem "$fingerprint" "$severity" "$root_cause"

            # Add solution
            local pattern=$(get_solution_pattern "$fingerprint")
            local steps='["Automatic fix available via auto-heal mode"]'
            json_add_solution "$pattern" "$fingerprint" "$steps"
        done
    fi

    json_print ""
    json_print "================================================================"
    json_print ""

    # Calculate health score
    local health_score=$(calculate_health_score "$service" "$machine")

    # Show recommended solutions or output JSON
    if is_json_output_mode; then
        # Add health score and categorized observations to JSON output
        local categorized=$(categorize_observations)

        # Build enhanced JSON output
        local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
        local observations="${JSON_DIAGNOSE_DATA[observations]}"
        local problems="${JSON_DIAGNOSE_DATA[problems]}"
        local solutions="${JSON_DIAGNOSE_DATA[solutions]}"

        # Add problem frequency and solution success rate to each problem
        local enhanced_problems=""
        local first=1
        for fingerprint in "${!IDENTIFIED_PROBLEMS[@]}"; do
            local problem_data="${IDENTIFIED_PROBLEMS[$fingerprint]}"
            local root_cause="${ROOT_CAUSES[$fingerprint]}"
            local severity="high"

            case "$fingerprint" in
                PROBLEM_SSH_CONNECTION_FAILED|PROBLEM_DOCKER_NOT_RUNNING)
                    severity="critical"
                    ;;
                PROBLEM_DEPENDENCY_UNHEALTHY|PROBLEM_PORT_CONFLICT)
                    severity="high"
                    ;;
                PROBLEM_DISK_SPACE_LOW|PROBLEM_STALE_PROCESS)
                    severity="medium"
                    ;;
                *)
                    severity="low"
                    ;;
            esac

            local frequency=$(get_problem_frequency "$fingerprint")
            local success_rate=$(get_solution_success_rate "$fingerprint")

            if [ $first -eq 0 ]; then
                enhanced_problems="$enhanced_problems,"
            fi
            first=0
            enhanced_problems="$enhanced_problems{\"id\":\"$fingerprint\",\"severity\":\"$severity\",\"description\":\"$(echo "$root_cause" | sed 's/"/\\"/g')\",\"frequency\":$frequency,\"success_rate\":$success_rate}"
        done

        cat <<EOF
{
  "service": "$service",
  "machine": "$machine",
  "health_score": $health_score,
  "categorized_observations": $categorized,
  "observations": [$observations],
  "problems": [$enhanced_problems],
  "solutions": [$solutions],
  "timestamp": "$timestamp"
}
EOF
    else
        # Enhanced text output
        json_print ""
        json_print_color "$BLUE" "HEALTH SCORE: $health_score/100"

        if [ $health_score -ge 90 ]; then
            json_print_color "$GREEN" "Status: HEALTHY"
        elif [ $health_score -ge 70 ]; then
            json_print_color "$YELLOW" "Status: DEGRADED"
        else
            json_print_color "$RED" "Status: UNHEALTHY"
        fi

        json_print ""
        json_print "================================================================"
        json_print ""

        local problems=$(get_identified_problems)
        if [ -n "$problems" ]; then
            solve_print INFO "PROBLEMS IDENTIFIED:"
            echo ""

            for fingerprint in $problems; do
                local pattern=$(get_solution_pattern "$fingerprint")
                local frequency=$(get_problem_frequency "$fingerprint")
                local success_rate=$(get_solution_success_rate "$fingerprint")

                echo "  Problem: $fingerprint"
                echo "  Frequency: Seen $frequency times in deployment history"
                echo "  Solution: $pattern (${success_rate}% success rate)"
                echo ""
                echo "  To auto-fix, run:"
                echo "    portoser deploy $machine $service"
                echo ""
            done
        else
            solve_print SUCCESS "No problems detected!"
            echo ""
            echo "  Service appears healthy and ready for deployment"
        fi

        # Generate report
        local report=$(generate_diagnostic_report "$service" "$machine")
        echo "Full diagnostic report: $report"
    fi
}

