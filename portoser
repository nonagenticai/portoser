# Parse natural deploy syntax: MACHINE1 SERVICE1 SERVICE2 MACHINE2 SERVICE3 ...
# Returns: Array of "SERVICE:MACHINE" pairs
# Usage: parse_deploy_args "$@"
parse_deploy_args() {
    local args=("$@")
    local deployments=()
    local current_machine=""

    for arg in "${args[@]}"; do
        if is_machine "$arg"; then
            # This is a machine - set as current target
            current_machine="$arg"
            [ "$DEBUG" = "1" ] && echo "Debug: Target machine set to: $current_machine" >&2
        elif is_service "$arg"; then
            # This is a service - deploy to current machine
            if [ -z "$current_machine" ]; then
                print_color "$RED" "Error: Service '$arg' specified before any target machine"
                print_color "$YELLOW" "Usage: portoser deploy MACHINE SERVICE [SERVICE...] [MACHINE SERVICE...]"
                return 1
            fi
            deployments+=("$arg:$current_machine")
            [ "$DEBUG" = "1" ] && echo "Debug: Added deployment: $arg -> $current_machine" >&2
        else
            # Unknown argument
            print_color "$RED" "Error: '$arg' is not a valid machine or service"
            echo "Available machines:" >&2
            list_machines | sed 's/^/  /' >&2
            echo "Available services:" >&2
            list_services | sed 's/^/  /' >&2
            return 1
        fi
    done

    if [ ${#deployments[@]} -eq 0 ]; then
        print_color "$RED" "Error: No services specified for deployment"
        return 1
    fi

    # Output deployments (one per line)
    printf '%s\n' "${deployments[@]}"
    return 0
}

# Smart deploy a single service to a target machine
# Automatically detects current location and deployment type, handles migration
# Usage: smart_deploy_service SERVICE TARGET_MACHINE
smart_deploy_service() {
    local service="$1"
    local target_machine="$2"

    if [ -z "$service" ] || [ -z "$target_machine" ]; then
        echo "Error: Service and target machine required" >&2
        return 1
    fi

    # Check and start dependencies first
    local dependencies=$(get_service_dependencies "$service" 2>/dev/null)
    if [ -n "$dependencies" ]; then
        echo "  Checking dependencies..."
        while IFS= read -r dep; do
            if [ -n "$dep" ]; then
                local dep_host=$(get_service_host "$dep" 2>/dev/null)
                if [ -z "$dep_host" ] || [ "$dep_host" = "null" ]; then
                    print_color "$YELLOW" "      ⚠ Warning: Dependency '$dep' is not deployed"
                    continue
                fi

                # Check if dependency is actually running and healthy
                local dep_ip=$(get_machine_ip "$dep_host")
                local dep_port=$(get_service_port "$dep")
                local dep_type=$(get_service_type "$dep")

                # Try health check
                local is_healthy=0
                if check_service_health "$dep" > /dev/null 2>&1; then
                    is_healthy=1
                    echo "      ✓ Dependency '$dep' is healthy on $dep_host"
                else
                    print_color "$YELLOW" "      ⚠ Dependency '$dep' is not responding on $dep_host"

                    # Try to start the dependency
                    print_color "$BLUE" "      → Starting dependency '$dep'..."

                    if [ "$dep_type" = "docker" ]; then
                        if docker_start "$dep" "$dep_host" > /dev/null 2>&1; then
                            echo "      ✓ Started Docker service '$dep'"
                            is_healthy=1
                        fi
                    else
                        if remote_start_service "$dep" "$dep_host" > /dev/null 2>&1; then
                            echo "      ✓ Started service '$dep'"
                            is_healthy=1
                        else
                            print_color "$RED" "      ✗ Failed to start '$dep' on $dep_host"
                        fi
                    fi

                    # Wait a moment and check health again
                    if [ $is_healthy -eq 1 ]; then
                        sleep 3
                        if check_service_health "$dep" > /dev/null 2>&1; then
                            echo "      ✓ Dependency '$dep' is now healthy"
                        else
                            print_color "$YELLOW" "      ⚠ Dependency '$dep' started but not yet healthy"
                        fi
                    fi
                fi
            fi
        done <<< "$dependencies"
    fi

    # Get service information
    local current_host=$(get_service_host "$service" 2>/dev/null)
    local service_type=$(get_service_type "$service")
    local port=$(get_service_port "$service")

    print_color "$BLUE" "Deploying $service to $target_machine..."

    # Determine action based on current state
    if [ -z "$current_host" ] || [ "$current_host" = "null" ]; then
        # Service not currently deployed - fresh deployment
        echo "  Action: Fresh deployment (not currently deployed)"

        if [ "$service_type" = "docker" ]; then
            if ! docker_deploy "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Deployment failed"
                return 1
            fi
        else
            if ! remote_start_service "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Deployment failed"
                return 1
            fi
        fi

        # Update registry
        update_service_host "$service" "$target_machine" > /dev/null
        local new_ip=$(get_machine_ip "$target_machine")
        update_service_health_url "$service" "http://$new_ip:$port/health" > /dev/null

        # Setup Caddy routing
        update_caddy_for_migration "$service" "none" "$target_machine" > /dev/null 2>&1

        # Verify DNS resolution
        echo "  Verifying DNS resolution..."
        if verify_dns_after_migration "$service" > /dev/null 2>&1; then
            echo "  ✓ DNS verified"
        else
            print_color "$YELLOW" "  ⚠ DNS verification failed - service may not be accessible via hostname"
        fi

        # Update metadata
        update_service_metadata "$service"

        print_color "$GREEN" "  ✓ Deployed successfully"

    elif [ "$current_host" = "$target_machine" ]; then
        # Service already on target machine - restart in place
        echo "  Action: Restart in place (already on $target_machine)"

        if [ "$service_type" = "docker" ]; then
            if ! docker_restart "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Restart failed"
                return 1
            fi
        else
            if ! remote_restart_service "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Restart failed"
                return 1
            fi
        fi

        # Update metadata
        update_service_metadata "$service"

        print_color "$GREEN" "  ✓ Restarted successfully"

    else
        # Service on different machine - migrate
        echo "  Action: Migrate (from $current_host to $target_machine)"

        # Step 1: Deploy to target
        echo "  [1/5] Deploying to $target_machine..."
        if [ "$service_type" = "docker" ]; then
            if ! docker_deploy "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Deployment to target failed"
                return 1
            fi
        else
            if ! remote_start_service "$service" "$target_machine"; then
                print_color "$RED" "  ✗ Deployment to target failed"
                return 1
            fi
        fi

        # Step 2: Update registry (so health check looks at new location)
        echo "  [2/5] Updating registry..."
        update_service_host "$service" "$target_machine" > /dev/null
        local new_ip=$(get_machine_ip "$target_machine")
        update_service_health_url "$service" "http://$new_ip:$port/health" > /dev/null

        # Step 3: Health check
        echo "  [3/5] Checking health..."
        if wait_for_service_health "$service" 30 > /dev/null 2>&1; then
            print_color "$GREEN" "      ✓ Service healthy"
        else
            print_color "$YELLOW" "      ⚠ Health check inconclusive, continuing..."
        fi

        # Step 4: Update Caddy
        echo "  [4/6] Updating Caddy routing..."
        if update_caddy_for_migration "$service" "$current_host" "$target_machine" > /dev/null 2>&1; then
            echo "      ✓ Caddy updated"
        else
            print_color "$YELLOW" "      ⚠ Caddy update had issues"
        fi

        # Step 5: Verify DNS resolution
        echo "  [5/6] Verifying DNS resolution..."
        if verify_dns_after_migration "$service" > /dev/null 2>&1; then
            echo "      ✓ DNS verified"
        else
            print_color "$YELLOW" "      ⚠ DNS verification failed - service may not be accessible via hostname"
        fi

        # Step 6: Stop old instance
        echo "  [6/6] Stopping old instance on $current_host..."
        if [ "$service_type" = "docker" ]; then
            docker_stop "$service" "$current_host" > /dev/null 2>&1 || print_color "$YELLOW" "      ⚠ Could not stop old instance"
        else
            remote_stop_service "$service" "$current_host" > /dev/null 2>&1 || print_color "$YELLOW" "      ⚠ Could not stop old instance"
        fi

        # Update metadata
        update_service_metadata "$service"

        print_color "$GREEN" "  ✓ Migration completed successfully"
    fi

    return 0
}

# Show deployment plan before executing
# Usage: show_deployment_plan DEPLOYMENTS_ARRAY
show_deployment_plan() {
    local deployments=("$@")

    echo ""
    print_color "$BLUE" "Deployment Plan:"
    print_color "$BLUE" "================"

    # Group by target machine
    declare -A machine_services

    for deployment in "${deployments[@]}"; do
        local service="${deployment%%:*}"
        local target="${deployment##*:}"

        if [ -z "${machine_services[$target]:-}" ]; then
            machine_services[$target]="$service"
        else
            machine_services[$target]="${machine_services[$target]} $service"
        fi
    done

    # Display plan
    # Use bash syntax for getting associative array keys
    for machine in "${!machine_services[@]}"; do
        echo ""
        print_color "$BLUE" "$machine:"

        for service in ${machine_services[$machine]}; do
            local current_host=$(get_service_host "$service" 2>/dev/null)
            local service_type=$(get_service_type "$service")

            if [ -z "$current_host" ] || [ "$current_host" = "null" ]; then
                echo "  - $service ($service_type) - FRESH DEPLOY"
            elif [ "$current_host" = "$machine" ]; then
                echo "  - $service ($service_type) - RESTART IN PLACE"
            else
                echo "  - $service ($service_type) - MIGRATE from $current_host"
            fi
        done
    done

    echo ""
}

