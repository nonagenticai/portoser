# Registry command handler
cmd_registry() {
    if [ $# -eq 0 ]; then
        echo "Usage: portoser registry <subcommand> [options]"
        echo ""
        echo "Query Commands:"
        echo "  list-services              List all services in registry"
        echo "  list-machines              List all machines in registry"
        echo "  show SERVICE               Show detailed info for a service"
        echo "  machine-info MACHINE       Show detailed info for a machine"
        echo "  validate                   Validate registry.yml structure"
        echo "  validate-ips               Validate service IPs match machine IPs"
        echo ""
        echo "Service Management Commands:"
        echo "  add-service NAME [OPTIONS] Add a new service to registry"
        echo "  update-service NAME [OPTS] Update service properties"
        echo "  move-service NAME --to M   Move service to different machine"
        echo "  remove-service NAME        Remove service from registry"
        echo ""
        echo "Machine Management Commands:"
        echo "  add-machine NAME [OPTIONS] Add a new machine to registry"
        echo "  sync-machine-ips MACHINE   Sync all service IPs for a machine"
        echo ""
        echo "Docker Registry Commands:"
        echo "  verify                     Compare registry vs filesystem (calls compare-registry.py)"
        echo "  scan [--update]            Scan services and optionally update registry"
        echo "  docker-start               Start Docker registry container"
        echo "  docker-stop                Stop Docker registry container"
        echo "  docker-restart             Restart Docker registry container"
        echo "  docker-health [--verbose]  Check Docker registry health"
        echo "  docker-images [--verbose]  List images in Docker registry"
        echo "  docker-auth <action>       Manage Docker registry authentication"
        echo "                             Actions: list, update, reset"
        echo "  docker-certs <action>      Manage Docker registry certificates"
        echo "                             Actions: list, check, update, distribute"
        echo "  docker-storage <action>    Manage Docker registry storage"
        echo "                             Actions: status, cleanup, prune"
        echo "  configure-pis [PI...]      Configure Pis for Docker registry access"
        echo ""
        echo "Examples:"
        echo "  # Query registry"
        echo "  portoser registry list-services"
        echo "  portoser registry show requirements"
        echo ""
        echo "  # Add a new service"
        echo "  portoser registry add-service my_api \\"
        echo "    --machine mini2 \\"
        echo "    --port 8080 \\"
        echo "    --type docker \\"
        echo "    --dependencies 'pgbouncer,keycloak' \\"
        echo "    --description 'My API service'"
        echo ""
        echo "  # Move service between machines"
        echo "  portoser registry move-service kag --to mini2"
        echo ""
        echo "  # Update service properties"
        echo "  portoser registry update-service kag --port 8801 --add-dependency neo4j"
        echo ""
        echo "  # Add a new machine"
        echo "  portoser registry add-machine mini3 \\"
        echo "    --ip 10.0.0.10 \\"
        echo "    --ssh-user deploy \\"
        echo "    --description 'Worker node'"
        exit 1
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        -h|--help)
            cmd_registry
            ;;

        # Query commands
        list-services)
            list_services
            ;;
        list-machines)
            list_machines
            ;;
        show)
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry show SERVICE"
                echo ""
                echo "Example: portoser registry show requirements"
                exit 1
            fi
            show_service "$1"
            ;;
        info)
            # Alias for 'show' for backwards compatibility
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry info SERVICE"
                echo ""
                echo "Example: portoser registry info requirements"
                exit 1
            fi
            show_service "$1"
            ;;
        machine-info)
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry machine-info MACHINE"
                echo ""
                echo "Example: portoser registry machine-info mini2"
                exit 1
            fi
            get_machine_info "$1"
            ;;
        validate)
            validate_registry
            ;;
        validate-ips)
            validate_service_ips
            ;;

        # Service management commands
        add-service)
            add_service "$@"
            ;;
        update-service)
            update_service "$@"
            ;;
        move-service)
            move_service "$@"
            ;;
        remove-service)
            remove_service "$@"
            ;;

        # Machine management commands
        add-machine)
            add_machine "$@"
            ;;
        sync-machine-ips)
            sync_machine_ips "$@"
            ;;

        # Registry verification command
        verify)
            # Compare registry.yml against actual services in filesystem
            # Calls scripts/compare-registry.py
            print_color "$BLUE" "Comparing registry.yml against filesystem..."

            local compare_script="$PORTOSER_ROOT/scripts/compare-registry.py"

            if [ ! -f "$compare_script" ]; then
                print_color "$RED" "Error: compare-registry.py not found at $compare_script"
                exit 1
            fi

            if ! command -v python3 &> /dev/null; then
                print_color "$RED" "Error: python3 is required for registry verification"
                exit 1
            fi

            python3 "$compare_script"
            ;;

        # Service scanning command
        scan)
            # Scan services on machines and optionally update registry
            local update_registry=false

            if [ "$1" = "--update" ]; then
                update_registry=true
                shift
            fi

            print_color "$BLUE" "Scanning services on this host..."

            # Use the python-based port extractor; for cluster-wide scans run
            # this on each host or extend the script with SSH yourself.
            local scan_script="$PORTOSER_ROOT/scripts/extract-ports.py"

            if [ ! -f "$scan_script" ]; then
                print_color "$RED" "Error: extract-ports.py not found at $scan_script"
                exit 1
            fi

            python3 "$scan_script"

            if [ "$update_registry" = true ]; then
                print_color "$YELLOW" "Updating registry with scan results..."
                print_color "$YELLOW" "Note: Automatic registry update not yet implemented"
                print_color "$YELLOW" "Please review scan results and update registry manually"
            fi
            ;;

        # Docker Registry Lifecycle Management
        docker-start)
            # Start Docker registry container
            print_color "$BLUE" "Starting Docker registry container..."
            registry_docker_start
            ;;

        docker-stop)
            # Stop Docker registry container
            print_color "$BLUE" "Stopping Docker registry container..."
            registry_docker_stop
            ;;

        docker-restart)
            # Restart Docker registry container
            print_color "$BLUE" "Restarting Docker registry container..."
            registry_docker_restart
            ;;

        # Docker Registry Health Check
        docker-health)
            # Check Docker registry health status
            local verbose=false

            if [ "$1" = "--verbose" ] || [ "$1" = "-v" ]; then
                verbose=true
            fi

            registry_docker_health "$verbose"
            ;;

        # Docker Registry Image Management
        docker-images)
            # List images in Docker registry
            local verbose=false

            if [ "$1" = "--verbose" ] || [ "$1" = "-v" ]; then
                verbose=true
            fi

            registry_docker_images "$verbose"
            ;;

        # Docker Registry Authentication Management
        docker-auth)
            # Manage Docker registry authentication
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry docker-auth <action> [options]"
                echo ""
                echo "Actions:"
                echo "  list                       List authenticated users"
                echo "  update USERNAME PASSWORD   Update user credentials"
                echo "  reset                      Reset to default credentials"
                echo ""
                echo "Examples:"
                echo "  portoser registry docker-auth list"
                echo "  portoser registry docker-auth update admin newpassword"
                echo "  portoser registry docker-auth reset"
                exit 1
            fi

            local action="$1"
            shift

            case "$action" in
                list)
                    registry_docker_auth_list
                    ;;
                update)
                    if [ $# -lt 2 ]; then
                        print_color "$RED" "Error: USERNAME and PASSWORD required"
                        echo "Usage: portoser registry docker-auth update USERNAME PASSWORD"
                        exit 1
                    fi
                    registry_docker_auth_update "$1" "$2"
                    ;;
                reset)
                    registry_docker_auth_reset
                    ;;
                *)
                    print_color "$RED" "Error: Unknown docker-auth action '$action'"
                    echo "Valid actions: list, update, reset"
                    exit 1
                    ;;
            esac
            ;;

        # Docker Registry Certificate Management
        docker-certs)
            # Manage Docker registry certificates
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry docker-certs <action> [options]"
                echo ""
                echo "Actions:"
                echo "  list                       List registry certificates"
                echo "  check [--days N]           Check certificate expiry (default: 30 days)"
                echo "  update                     Regenerate certificates"
                echo "  distribute [PI...]         Distribute CA to Pis"
                echo ""
                echo "Examples:"
                echo "  portoser registry docker-certs list"
                echo "  portoser registry docker-certs check --days 60"
                echo "  portoser registry docker-certs update"
                echo "  portoser registry docker-certs distribute pi1 pi2"
                exit 1
            fi

            local action="$1"
            shift

            case "$action" in
                list)
                    registry_docker_certs_list
                    ;;
                check)
                    local days=30
                    if [ "$1" = "--days" ] && [ -n "$2" ]; then
                        days="$2"
                    fi
                    registry_docker_certs_check "$days"
                    ;;
                update)
                    registry_docker_certs_update
                    ;;
                distribute)
                    registry_docker_certs_distribute "$@"
                    ;;
                *)
                    print_color "$RED" "Error: Unknown docker-certs action '$action'"
                    echo "Valid actions: list, check, update, distribute"
                    exit 1
                    ;;
            esac
            ;;

        # Docker Registry Storage Management
        docker-storage)
            # Manage Docker registry storage
            if [ $# -eq 0 ]; then
                echo "Usage: portoser registry docker-storage <action>"
                echo ""
                echo "Actions:"
                echo "  status                     Show storage usage"
                echo "  cleanup                    Remove orphaned blobs"
                echo "  prune                      Prune unused layers"
                echo ""
                echo "Examples:"
                echo "  portoser registry docker-storage status"
                echo "  portoser registry docker-storage cleanup"
                echo "  portoser registry docker-storage prune"
                exit 1
            fi

            local action="$1"
            shift

            case "$action" in
                status)
                    registry_docker_storage_status
                    ;;
                cleanup)
                    registry_docker_storage_cleanup
                    ;;
                prune)
                    registry_docker_storage_prune
                    ;;
                *)
                    print_color "$RED" "Error: Unknown docker-storage action '$action'"
                    echo "Valid actions: status, cleanup, prune"
                    exit 1
                    ;;
            esac
            ;;

        # Configure Pis for Docker Registry Access
        configure-pis)
            # Configure Raspberry Pis for Docker registry access
            print_color "$BLUE" "Configuring Pis for Docker registry access..."

            # If specific Pis provided, use them; otherwise configure all
            local pis=("$@")

            if [ ${#pis[@]} -eq 0 ]; then
                # Default to all Pis
                pis=("pi1" "pi2" "pi3" "pi4")
                print_color "$YELLOW" "No Pis specified, configuring all: ${pis[*]}"
            fi

            registry_configure_pis "${pis[@]}"
            ;;

        *)
            print_color "$RED" "Error: Unknown registry subcommand '$subcommand'"
            echo ""
            cmd_registry
            ;;
    esac
}

# Bootstrap remote machine with portoser libraries
# Usage: remote_bootstrap MACHINE [--install-docker] [--install-deps] [--force]
remote_bootstrap() {
    local machine=""
    local install_docker=false
    local install_deps=false
    local force=false

    # Parse arguments
    while [ $# -gt 0 ]; do
        case "$1" in
            --install-docker)
                install_docker=true
                shift
                ;;
            --install-deps)
                install_deps=true
                shift
                ;;
            --force)
                force=true
                shift
                ;;
            -*)
                echo "Error: Unknown option '$1'" >&2
                echo "Usage: portoser remote bootstrap MACHINE [--install-docker] [--install-deps] [--force]" >&2
                return 1
                ;;
            *)
                if [ -z "$machine" ]; then
                    machine="$1"
                else
                    echo "Error: Too many arguments. Machine already specified as '$machine'" >&2
                    return 1
                fi
                shift
                ;;
        esac
    done

    if [ -z "$machine" ]; then
        echo "Error: Machine name required" >&2
        echo "Usage: portoser remote bootstrap MACHINE [--install-docker] [--install-deps] [--force]" >&2
        return 1
    fi

    echo "========================================"
    echo "Bootstrap Remote Machine: $machine"
    echo "========================================"
    echo ""

    # Step 1: Resolve machine connection info
    echo "[1/9] Resolving machine connection info..."
    local ip
    ip=$(get_machine_ip "$machine")
    if [ $? -ne 0 ]; then
        echo "✗ Failed to resolve IP for machine: $machine" >&2
        return 1
    fi

    local ssh_user
    ssh_user=$(get_machine_ssh_user "$machine")
    local ssh_port
    ssh_port=$(get_machine_ssh_port "$machine")

    echo "  Machine: $machine"
    echo "  IP: $ip"
    echo "  SSH User: $ssh_user"
    echo "  SSH Port: $ssh_port"
    echo ""

    # Step 2: Check SSH connectivity
    echo "[2/9] Testing SSH connectivity..."
    if ! check_ssh_connection "$machine"; then
        echo "✗ Cannot connect to $machine via SSH" >&2
        echo "  Please verify:" >&2
        echo "  - Machine is powered on and accessible" >&2
        echo "  - SSH key is configured (try: ssh-copy-id $ssh_user@$ip)" >&2
        echo "  - SSH service is running on remote machine" >&2
        return 1
    fi
    echo "✓ SSH connection successful"
    echo ""

    # Step 3: Check if already bootstrapped (unless --force)
    if [ "$force" = false ]; then
        echo "[3/9] Checking if already bootstrapped..."
        if remote_file_exists "$machine" "~/.portoser_lib/platform/detector.sh" 2>/dev/null; then
            echo "  Remote machine appears to be already bootstrapped."
            echo "  Use --force to re-bootstrap anyway."

            # Show current capabilities
            local caps_file="$HOME/.portoser/remote_caps/${machine}.json"
            if [ -f "$caps_file" ]; then
                echo ""
                echo "  Current capabilities:"
                cat "$caps_file" | jq -r '.dependencies | to_entries[] | "    \(.key): \(.value)"' 2>/dev/null || cat "$caps_file"
            fi
            echo ""
            echo "Bootstrap skipped (already exists). Use --force to reinstall."
            return 0
        fi
        echo "  Not bootstrapped yet, proceeding..."
        echo ""
    else
        echo "[3/9] Force mode enabled, skipping bootstrap check..."
        echo ""
    fi

    # Step 4: Create remote directories
    echo "[4/9] Creating remote directories..."
    local remote_dirs=(
        "~/.portoser_lib"
        "~/.portoser_lib/metrics"
        "~/.portoser_lib/platform"
        "~/.portoser_lib/observe"
        "~/.portoser_lib/diagnose"
        "~/.portoser_lib/solve"
        "~/.portoser_lib/solve/patterns"
        "~/.portoser_lib/standardize"
        "~/.portoser_lib/history"
        "~/.portoser_lib/dependencies"
        "~/.portoser_lib/health"
    )

    for dir in "${remote_dirs[@]}"; do
        if ! remote_mkdir "$machine" "$dir" >/dev/null 2>&1; then
            echo "✗ Failed to create directory: $dir" >&2
            return 1
        fi
    done
    echo "✓ Remote directories created"
    echo ""

    # Step 5: Sync library files
    echo "[5/9] Syncing library files..."
    if ! remote_sync_libs "$machine" "metrics" "platform" "observe" "diagnose" "solve" "standardize" "history" "dependencies" "health"; then
        echo "✗ Failed to sync library files" >&2
        return 1
    fi
    echo ""

    # Step 6: Create remote env.sh
    echo "[6/9] Creating remote environment setup..."
    local env_script='#!/usr/bin/env bash
# Portoser remote environment
export PORTOSER_BASE="$HOME/.portoser_lib"
export PATH="$PORTOSER_BASE/bin:$PATH"

# Helper function to source portoser libs
source_portoser_lib() {
    local lib="$1"
    if [ -f "$PORTOSER_BASE/$lib" ]; then
        source "$PORTOSER_BASE/$lib"
        return 0
    else
        echo "Warning: Portoser library not found: $lib" >&2
        return 1
    fi
}
'

    if ! remote_exec "$machine" "cat > ~/.portoser_lib/env.sh << 'PORTOSER_ENV_EOF'
$env_script
PORTOSER_ENV_EOF
chmod +x ~/.portoser_lib/env.sh" >/dev/null 2>&1; then
        echo "✗ Failed to create remote env.sh" >&2
        return 1
    fi
    echo "✓ Remote environment configured"
    echo ""

    # Step 7: Run remote dependency check
    echo "[7/9] Checking remote dependencies..."
    local dep_check_script='
source ~/.portoser_lib/env.sh 2>/dev/null

check_cmd() {
    local cmd="$1"
    local optional="${2:-false}"
    if command -v "$cmd" >/dev/null 2>&1; then
        echo "$cmd:installed:$(command -v "$cmd")"
        return 0
    else
        if [ "$optional" = "true" ]; then
            echo "$cmd:optional_missing:"
        else
            echo "$cmd:missing:"
        fi
        return 1
    fi
}

# Required dependencies
check_cmd bash false
check_cmd bc false
check_cmd df false
check_cmd free false
check_cmd jq false
check_cmd yq false

# Optional dependencies
check_cmd docker true
check_cmd rsync true

# Additional useful commands
check_cmd git true
check_cmd curl true
check_cmd wget true
'

    local dep_results
    dep_results=$(remote_exec "$machine" "$dep_check_script" 2>/dev/null)

    local missing_deps=()
    local optional_missing=()

    echo "  Dependency Status:"
    while IFS=':' read -r cmd status path; do
        if [ "$status" = "installed" ]; then
            echo "    ✓ $cmd"
        elif [ "$status" = "missing" ]; then
            echo "    ✗ $cmd (required)"
            missing_deps+=("$cmd")
        elif [ "$status" = "optional_missing" ]; then
            echo "    - $cmd (optional, not installed)"
            optional_missing+=("$cmd")
        fi
    done <<< "$dep_results"
    echo ""

    # Step 8: Install missing dependencies if requested
    if [ ${#missing_deps[@]} -gt 0 ]; then
        if [ "$install_deps" = true ]; then
            echo "[8/9] Installing missing dependencies..."

            # Detect distro
            local distro
            distro=$(remote_exec "$machine" "
                if [ -f /etc/os-release ]; then
                    . /etc/os-release
                    echo \$ID
                elif [ -f /etc/redhat-release ]; then
                    echo 'rhel'
                else
                    echo 'unknown'
                fi
            " 2>/dev/null | tr -d '\r\n')

            echo "  Detected distro: $distro"

            case "$distro" in
                ubuntu|debian)
                    echo "  Installing via apt-get..."
                    local install_cmd="sudo apt-get update && sudo apt-get install -y bash bc coreutils jq"

                    # Install yq separately (not in standard repos)
                    install_cmd="$install_cmd && curl -fsSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -o /tmp/yq && sudo mv /tmp/yq /usr/local/bin/yq && sudo chmod +x /usr/local/bin/yq"

                    if remote_exec "$machine" "$install_cmd" >/dev/null 2>&1; then
                        echo "  ✓ Dependencies installed"
                    else
                        echo "  ✗ Failed to install dependencies" >&2
                        echo "  Please install manually: ${missing_deps[*]}" >&2
                    fi
                    ;;
                centos|rhel|fedora)
                    echo "  Installing via yum..."
                    local install_cmd="sudo yum install -y bash bc coreutils jq"

                    # Install yq separately
                    install_cmd="$install_cmd && curl -fsSL https://github.com/mikefarah/yq/releases/latest/download/yq_linux_amd64 -o /tmp/yq && sudo mv /tmp/yq /usr/local/bin/yq && sudo chmod +x /usr/local/bin/yq"

                    if remote_exec "$machine" "$install_cmd" >/dev/null 2>&1; then
                        echo "  ✓ Dependencies installed"
                    else
                        echo "  ✗ Failed to install dependencies" >&2
                        echo "  Please install manually: ${missing_deps[*]}" >&2
                    fi
                    ;;
                *)
                    echo "  ✗ Unknown distro, cannot auto-install" >&2
                    echo "  Please install manually: ${missing_deps[*]}" >&2
                    ;;
            esac
            echo ""
        else
            echo "[8/9] Missing required dependencies (use --install-deps to auto-install):"
            for dep in "${missing_deps[@]}"; do
                echo "    - $dep"
            done
            echo ""
            echo "✗ Bootstrap incomplete: missing dependencies" >&2
            return 1
        fi
    else
        echo "[8/9] All required dependencies present"
        echo ""
    fi

    # Install Docker if requested
    if [ "$install_docker" = true ] && [[ " ${optional_missing[@]} " =~ " docker " ]]; then
        echo "  Installing Docker..."

        local distro
        distro=$(remote_exec "$machine" "
            if [ -f /etc/os-release ]; then
                . /etc/os-release
                echo \$ID
            else
                echo 'unknown'
            fi
        " 2>/dev/null | tr -d '\r\n')

        case "$distro" in
            ubuntu|debian)
                local docker_install_cmd="
                    curl -fsSL https://get.docker.com -o /tmp/get-docker.sh &&
                    sudo sh /tmp/get-docker.sh &&
                    sudo usermod -aG docker \$USER
                "
                if remote_exec "$machine" "$docker_install_cmd" >/dev/null 2>&1; then
                    echo "  ✓ Docker installed"
                    echo "  Note: User needs to log out and back in for docker group to take effect"
                else
                    echo "  ✗ Failed to install Docker" >&2
                fi
                ;;
            centos|rhel|fedora)
                local docker_install_cmd="
                    sudo yum install -y yum-utils &&
                    sudo yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo &&
                    sudo yum install -y docker-ce docker-ce-cli containerd.io &&
                    sudo systemctl start docker &&
                    sudo systemctl enable docker &&
                    sudo usermod -aG docker \$USER
                "
                if remote_exec "$machine" "$docker_install_cmd" >/dev/null 2>&1; then
                    echo "  ✓ Docker installed"
                    echo "  Note: User needs to log out and back in for docker group to take effect"
                else
                    echo "  ✗ Failed to install Docker" >&2
                fi
                ;;
            *)
                echo "  ✗ Unknown distro, cannot auto-install Docker" >&2
                ;;
        esac
        echo ""
    fi

    # Step 9: Run metrics smoke test
    echo "[9/9] Running metrics smoke test..."
    local metrics_test
    metrics_test=$(remote_exec "$machine" "
        source ~/.portoser_lib/env.sh 2>/dev/null
        source ~/.portoser_lib/platform/detector.sh 2>/dev/null
        source ~/.portoser_lib/metrics/collector.sh 2>/dev/null

        get_system_metrics_json 2>/dev/null || echo '{\"error\":\"metrics_unavailable\"}'
    " 2>/dev/null)

    if echo "$metrics_test" | jq -e '.error' >/dev/null 2>&1; then
        echo "✗ Metrics smoke test failed" >&2
        echo "  Metrics may not be fully functional on this platform" >&2
        echo "  This is non-fatal, but metrics collection may not work correctly" >&2
    else
        echo "✓ Metrics smoke test passed"
        if [ "${DEBUG:-0}" = "1" ]; then
            echo "  Sample metrics:"
            echo "$metrics_test" | jq -C '.' 2>/dev/null | head -10
        fi
    fi
    echo ""

    # Save capabilities to local cache
    echo "Saving machine capabilities..."
    local caps_dir="$HOME/.portoser/remote_caps"
    mkdir -p "$caps_dir"

    local caps_json="{
  \"machine\": \"$machine\",
  \"ip\": \"$ip\",
  \"ssh_user\": \"$ssh_user\",
  \"ssh_port\": $ssh_port,
  \"bootstrapped_at\": \"$(date -u +"%Y-%m-%dT%H:%M:%SZ")\",
  \"dependencies\": {"

    local first=true
    while IFS=':' read -r cmd status path; do
        if [ -n "$cmd" ]; then
            [ "$first" = false ] && caps_json+=","
            first=false
            local installed="false"
            [ "$status" = "installed" ] && installed="true"
            caps_json+="
    \"$cmd\": $installed"
        fi
    done <<< "$dep_results"

    caps_json+="
  },
  \"metrics_available\": $(echo "$metrics_test" | jq -e '.error' >/dev/null 2>&1 && echo "false" || echo "true")
}"

    echo "$caps_json" > "$caps_dir/${machine}.json"
    echo "✓ Capabilities saved to: $caps_dir/${machine}.json"
    echo ""

    echo "========================================"
    echo "✓ Bootstrap Complete!"
    echo "========================================"
    echo ""
    echo "Machine '$machine' is now ready for remote operations."
    echo ""
    echo "Next steps:"
    echo "  - Test metrics: portoser metrics machine $machine"
    echo "  - Run diagnostics: portoser diagnose <service> $machine"
    echo "  - Deploy services: portoser deploy <service> $machine"
    echo ""

    return 0
}

