# Move command handler (orchestrates service migration)
cmd_move() {
    if [ $# -lt 3 ]; then
        echo "Usage: portoser move SERVICE FROM_MACHINE TO_MACHINE"
        exit 1
    fi

    local service="$1"
    local from_machine="$2"
    local to_machine="$3"

    print_color "$BLUE" "==========================================="
    print_color "$BLUE" "MOVING SERVICE: $service"
    print_color "$BLUE" "FROM: $from_machine → TO: $to_machine"
    print_color "$BLUE" "==========================================="
    echo ""

    # Step 1: Verify current location matches FROM_MACHINE
    local current_host=$(get_service_host "$service")
    if [ "$current_host" != "$from_machine" ]; then
        print_color "$YELLOW" "Warning: Service '$service' is currently on '$current_host', not '$from_machine' - using '$current_host'"
        from_machine="$current_host"
    fi

    # Step 2: Get service type
    local service_type=$(get_service_type "$service")
    print_color "$BLUE" "Service type: $service_type"
    echo ""

    # Step 3: Deploy to target machine
    print_color "$BLUE" "Step 1: Deploying $service to $to_machine..."
    if [ "$service_type" = "docker" ]; then
        if ! docker_deploy "$service" "$to_machine"; then
            print_color "$RED" "✗ Deployment failed"
            exit 1
        fi
    else
        if ! remote_start_service "$service" "$to_machine"; then
            print_color "$RED" "✗ Deployment failed"
            exit 1
        fi
    fi
    print_color "$GREEN" "✓ Deployed successfully"
    echo ""

    # Step 4: Health check
    print_color "$BLUE" "Step 2: Checking health of new deployment..."
    # Update registry temporarily to check new location
    update_service_host "$service" "$to_machine" > /dev/null

    if wait_for_service_health "$service" 30; then
        print_color "$GREEN" "✓ Service is healthy on $to_machine"
    else
        print_color "$YELLOW" "⚠ Health check failed, but continuing..."
    fi
    echo ""

    # Step 5: Update Caddy
    print_color "$BLUE" "Step 3: Updating Caddy routing..."
    if update_caddy_for_migration "$service" "$from_machine" "$to_machine"; then
        print_color "$GREEN" "✓ Caddy updated"
    else
        print_color "$YELLOW" "⚠ Caddy update had issues, check manually"
    fi
    echo ""

    # Step 5.5: Verify DNS resolution
    print_color "$BLUE" "Step 4: Verifying DNS resolution..."
    if verify_dns_after_migration "$service" > /dev/null 2>&1; then
        print_color "$GREEN" "✓ DNS verified"
    else
        print_color "$YELLOW" "⚠ DNS verification failed - service may not be accessible via hostname"
    fi
    echo ""

    # Step 6: Update registry
    print_color "$BLUE" "Step 5: Updating registry..."
    local port=$(get_service_port "$service")
    local new_ip=$(get_machine_ip "$to_machine")
    update_service_health_url "$service" "http://$new_ip:$port/health" > /dev/null
    print_color "$GREEN" "✓ Registry updated"
    echo ""

    # Step 7: Stop old instance
    print_color "$BLUE" "Step 6: Stopping old instance on $from_machine..."
    if [ "$service_type" = "docker" ]; then
        docker_stop "$service" "$from_machine" || print_color "$YELLOW" "⚠ Failed to stop old instance"
    else
        remote_stop_service "$service" "$from_machine" || print_color "$YELLOW" "⚠ Failed to stop old instance"
    fi
    echo ""

    print_color "$GREEN" "==========================================="
    print_color "$GREEN" "✓ MIGRATION COMPLETED SUCCESSFULLY"
    print_color "$GREEN" "==========================================="
    print_color "$GREEN" "Service '$service' is now running on $to_machine"
    echo ""
}

# Start command handler (registry-aware)
cmd_start() {
    if [ $# -eq 0 ]; then
        echo "Usage: portoser start <service|machine> [service...]"
        echo ""
        echo "Examples:"
        echo "  portoser start requirements          # Start service (registry knows where/how)"
        echo "  portoser start mini2                 # Start all services on mini2"
        echo "  portoser start mini2 requirements kag # Start specific services on mini2"
        exit 1
    fi

    local first_arg="$1"

    # Check if first argument is a machine or service
    if is_machine "$first_arg"; then
        # Machine-based start
        local machine="$first_arg"
        shift
        local services=("$@")

        if [ ${#services[@]} -eq 0 ]; then
            # Start all services on machine
            print_color "$BLUE" "Starting all services on $machine..."
            start_machine_services "$machine"
        else
            # Start specific services on machine
            print_color "$BLUE" "Starting services on $machine: ${services[*]}"
            start_machine_services "$machine" "${services[@]}"
        fi
    elif is_service "$first_arg"; then
        # Service-based start
        local service="$first_arg"
        print_color "$BLUE" "Starting service: $service"
        smart_start_service "$service"
        local exit_code="$?"
        exit "$exit_code"
    else
        print_color "$RED" "Error: '$first_arg' is neither a registered machine nor service"
        exit 1
    fi
}

