        echo "  portoser vault migrate-all"
        echo "  portoser vault get keycloak"
        echo "  portoser vault put keycloak NEW_KEY new_value"
        exit 1
    fi

    local subcommand="$1"
    shift

    case "$subcommand" in
        -h|--help)
            cmd_vault
            ;;
        init)
            vault_init
            ;;
        unseal)
            vault_unseal "$@"
            ;;
        status)
            vault_status
            ;;
        setup-approles)
            print_color "$BLUE" "Creating AppRoles for all machines..."
            echo ""
            local machines=$(list_machines)
            while IFS= read -r machine; do
                if [ -n "$machine" ]; then
                    vault_create_approle "$machine"
                    echo ""
                fi
            done <<< "$machines"
            print_color "$GREEN" "✓ AppRoles created for all machines"
            ;;
        migrate)
            if [ $# -eq 0 ]; then
                echo "Usage: portoser vault migrate SERVICE"
                exit 1
            fi
            local service="$1"
            local service_dir=$(get_service_directory "$service" 2>/dev/null)

            if [ -z "$service_dir" ] || [ ! -d "$service_dir" ]; then
                print_color "$RED" "Error: Service directory not found for $service"
                exit 1
            fi

            local env_file="$service_dir/.env"
            if [ ! -f "$env_file" ]; then
                print_color "$RED" "Error: .env file not found at $env_file"
                exit 1
            fi

            vault_migrate_env "$service" "$env_file"
            ;;
        migrate-all)
            print_color "$BLUE" "Migrating all service .env files to Vault..."
            echo ""

            local services=$(list_services)
            local migrated=0
            local skipped=0

            while IFS= read -r service; do
                if [ -z "$service" ]; then
                    continue
                fi

                local service_dir=$(get_service_directory "$service" 2>/dev/null)

                if [ -z "$service_dir" ] || [ ! -d "$service_dir" ]; then
                    echo "  Skipping $service (no directory found)"
                    skipped=$((skipped + 1))
                    continue
                fi

                local env_file="$service_dir/.env"
                if [ ! -f "$env_file" ]; then
                    echo "  Skipping $service (no .env file)"
                    skipped=$((skipped + 1))
                    continue
                fi

                if vault_migrate_env "$service" "$env_file" 2>/dev/null; then
                    migrated=$((migrated + 1))
                else
                    skipped=$((skipped + 1))
                fi
                echo ""
            done <<< "$services"

            print_color "$GREEN" "✓ Migration complete: $migrated migrated, $skipped skipped"
            ;;
        get)
            if [ $# -eq 0 ]; then
                echo "Usage: portoser vault get SERVICE"
                exit 1
            fi
            vault_list_service_secrets "$1"
            ;;
        put)
            if [ $# -lt 3 ]; then
                echo "Usage: portoser vault put SERVICE KEY VALUE"
                exit 1
            fi
            local service="$1"
            local key="$2"
            local value="$3"

            if vault_put_secret "services/$service" "$key" "$value"; then
                print_color "$GREEN" "✓ Secret stored: $service/$key"
            else
                print_color "$RED" "✗ Failed to store secret"
                exit 1
            fi
            ;;
        list)
            vault_list_all_services
            ;;
        *)
            print_color "$RED" "Error: Unknown vault subcommand '$subcommand'"
            echo ""
            cmd_vault
            ;;
    esac
}

