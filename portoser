# Load environment variables. Previously this used `set -a; source .env`
# which clobbers anything the caller has already exported (e.g. tests
# pinning CADDY_REGISTRY_PATH to a fixture path). Load .env into a sub-
# environment first, then apply only the keys the parent shell hasn't
# already set.
if [ -z "${PORTOSER_SKIP_ENV:-}" ] && [ -f "$SCRIPT_DIR/.env" ]; then
    while IFS= read -r _line; do
        # Strip CR (in case .env was edited on Windows).
        _line="${_line%$'\r'}"
        # Skip blanks and comments.
        case "$_line" in
            ''|'#'*) continue ;;
        esac
        # Allow optional leading `export ` prefix.
        case "$_line" in
            'export '*) _line="${_line#export }" ;;
        esac
        # Must look like KEY=VALUE with a valid identifier.
        case "$_line" in
            [A-Za-z_]*=*) ;;
            *) continue ;;
        esac
        _key="${_line%%=*}"
        _value="${_line#*=}"
        # Already set in the caller's env? Honour the caller.
        if [ -n "${!_key+x}" ]; then
            continue
        fi
        # Strip optional surrounding single/double quotes.
        case "$_value" in
            \"*\") _value="${_value#\"}"; _value="${_value%\"}" ;;
            \'*\') _value="${_value#\'}"; _value="${_value%\'}" ;;
        esac
        # Expand ${HOME}, $USER, etc. that .env files commonly use.
        _value="$(eval "printf '%s' \"$_value\"")"
        export "$_key=$_value"
    done < "$SCRIPT_DIR/.env"
    unset _line _key _value
fi

