# Check for required dependencies
check_dependencies() {
    local missing_deps=()
    local required_cmds=("yq" "jq" "ssh" "scp" "curl")
    local optional_cmds=("docker" "rsync" "lsof")

    for cmd in "${required_cmds[@]}"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing_deps+=("$cmd (required)")
        fi
    done

    if [ ${#missing_deps[@]} -gt 0 ]; then
        echo "Error: Missing required dependencies:" >&2
        printf '  - %s\n' "${missing_deps[@]}" >&2
        echo "" >&2
        echo "Please install the missing dependencies and try again." >&2
        exit 1
    fi

    # Warn about missing optional dependencies
    local missing_optional=()
    for cmd in "${optional_cmds[@]}"; do
        if ! command -v "$cmd" >/dev/null 2>&1; then
            missing_optional+=("$cmd")
        fi
    done

    if [ ${#missing_optional[@]} -gt 0 ] && [ "${DEBUG:-0}" = "1" ]; then
        echo "Warning: Missing optional dependencies:" >&2
        printf '  - %s\n' "${missing_optional[@]}" >&2
        echo "Some features may not work without these commands." >&2
        echo "" >&2
    fi
}

