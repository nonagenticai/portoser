# Main command dispatcher
main() {
    if [ $# -eq 0 ]; then
        usage
        exit 0
    fi

    # Handle global options
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        -v|--version)
            version
            exit 0
            ;;
        --debug)
            export DEBUG=1
            shift
            ;;
    esac

    # Skip registry validation if the user is just asking for help on a
    # subcommand (or running 'help'/'version'). This lets a fresh OSS clone
    # explore the CLI before copying registry.example.yml -> registry.yml.
    local _needs_registry=1
    case "${1:-}" in
        ''|help|version)
            # Bare `portoser` and `portoser <command>` (no subcommand) print
            # their own usage; no registry needed.
            _needs_registry=0
            ;;
    esac
    if [ "$_needs_registry" -eq 1 ] && [ $# -le 1 ]; then
        # `portoser <command>` with no further args — most dispatchers
        # print their subcommand usage in this case, so skip validation.
        _needs_registry=0
    fi
    if [ "$_needs_registry" -eq 1 ]; then
        for _arg in "$@"; do
            case "$_arg" in
                -h|--help)
                    _needs_registry=0
                    break
                    ;;
            esac
        done
    fi

    # Validate registry first (unless skipped above)
    if [ "$_needs_registry" -eq 1 ] && ! validate_registry > /dev/null 2>&1; then
        print_color "$RED" "Error: Registry file is invalid or not found"
        print_color "$YELLOW" "  Path: $CADDY_REGISTRY_PATH"
