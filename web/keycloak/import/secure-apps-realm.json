{
  "realm": "secure-apps",
  "displayName": "Portoser (local dev)",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "accessTokenLifespan": 7200,
  "ssoSessionIdleTimeout": 28800,
  "ssoSessionMaxLifespan": 86400,
  "roles": {
    "realm": [
      { "name": "admin",  "description": "Full access to portoser-web" },
      { "name": "viewer", "description": "Read-only access" }
    ]
  },
  "clients": [
    {
      "clientId": "portoser",
      "name": "Portoser Web",
      "enabled": true,
      "publicClient": false,
      "secret": "portoser-local-dev-secret",
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "7200"
      },
      "defaultClientScopes": [
        "basic",
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@portoser.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin", "viewer"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "email": "viewer@portoser.local",
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "viewer", "temporary": false }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
