# Portoser Web Backend Configuration Template
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# ===========================
# ENVIRONMENT
# ===========================
ENVIRONMENT=development
# Options: development, staging, production
# IMPORTANT: Set to 'production' for production deployments

# ===========================
# JWT AUTHENTICATION
# ===========================
# CRITICAL: Generate a strong secret for production!
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=dev-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ===========================
# KEYCLOAK (Optional)
# ===========================
KEYCLOAK_ENABLED=false
KEYCLOAK_URL=https://keycloak.example.com
KEYCLOAK_REALM=secure-apps
KEYCLOAK_CLIENT_ID=portoser
KEYCLOAK_CLIENT_SECRET=
# Get from: ./scripts/setup-keycloak-client.sh
#   (see the script's header comment for required env vars)

# Admin password for Keycloak setup script (store securely!)
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# ADMIN_PASSWORD=

# ===========================
# MCP (Model Context Protocol)
# ===========================
MCP_ENABLED=true

# ===========================
# POSTGRESQL DATABASE
# ===========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=enterprise_mcp_server
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# CRITICAL: Change password in production!
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
POSTGRES_POOL_MIN_SIZE=2
POSTGRES_POOL_MAX_SIZE=10
POSTGRES_ADMIN_DB=postgres

# ===========================
# VAULT (Optional)
# ===========================
VAULT_ENABLED=false
VAULT_ADDR=https://vault.example.com:8200
VAULT_TOKEN=
# Get from: vault login

# ===========================
# SERVICE REGISTRY
# ===========================
# Adjust paths based on your installation directory
CADDY_REGISTRY_PATH=/path/to/portoser/registry.yml
CADDYFILE_PATH=/path/to/caddy/Caddyfile
CADDY_ADMIN_API=http://127.0.0.1:2019

# ===========================
# SERVICE PATHS
# ===========================
SERVICES_ROOT=/path/to/services
PIDS_DIR=/path/to/.pids
LOGS_DIR=/path/to/.logs

# ===========================
# NETWORKING
# ===========================
DOCKER_NETWORK=workflow-system-network

# ===========================
# HEALTH CHECKS
# ===========================
HEALTH_CHECK_TIMEOUT=30
HEALTH_CHECK_INTERVAL=2

# ===========================
# SSH
# ===========================
SSH_USER=your-username

# ===========================
# METRICS
# ===========================
METRICS_COLLECTION_INTERVAL=120
# Interval in seconds for background metrics collection
# Lower values = more frequent updates but higher SSH overhead

# ===========================
# WEBSOCKET
# ===========================
MAX_WEBSOCKET_CONNECTIONS=100
# Maximum concurrent WebSocket connections

# ===========================
# REDIS (Caching and Rate Limiting)
# ===========================
REDIS_ENABLED=false
# Set to true to enable Redis caching and rate limiting features
REDIS_HOST=localhost
REDIS_PORT=8987
# Note: 8987 is the default port in docker-compose, not standard Redis 6379
REDIS_DB=0
REDIS_URL=redis://localhost:8987/0
# REDIS_URL takes precedence if set, otherwise constructed from HOST/PORT/DB

# ===========================
# BACKEND API
# ===========================
BACKEND_PORT=8988
# Port for the FastAPI backend server

# ===========================
# DEBUG
# ===========================
DEBUG=0
# Set to 1 to enable debug logging (not recommended for production)
