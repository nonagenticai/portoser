# Portoser Frontend Configuration Template
# Copy this file to .env and fill in your actual values
# Command: cp .env.example .env

# ===========================
# DEVELOPMENT SERVER
# ===========================
# Port for the Vite development server
VITE_DEV_PORT=8989

# ===========================
# API ENDPOINTS
# ===========================
# Backend API URL (for development, proxied via Vite)
# In production, this should point to your actual API server
VITE_API_URL=http://localhost:8988

# WebSocket URL (for development, proxied via Vite)
# In production, this should point to your actual WebSocket server
VITE_WS_URL=ws://localhost:8988

# ===========================
# DEPLOYMENT SETTINGS
# ===========================
# Timeout in milliseconds for clearing deployment logs after completion (~9s).
VITE_DEPLOYMENT_CLEAR_TIMEOUT=9000
