# ==============================================================================
# Portoser Web - Secrets Configuration
# ==============================================================================
# IMPORTANT: This file contains ONLY secrets (passwords, keys, tokens)
# All other configuration belongs in docker-compose.yml
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Generate secrets using the commands below
# 3. Fill in the actual values in .env
# 4. NEVER commit .env to version control!
# ==============================================================================

# ------------------------------------------------------------------------------
# Database Credentials
# ------------------------------------------------------------------------------
# CRITICAL: Change in production!
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
POSTGRES_PASSWORD_PORTOSER=CHANGE_ME_SECURE_PASSWORD

# ------------------------------------------------------------------------------
# Keycloak Authentication
# ------------------------------------------------------------------------------
# Get from Keycloak setup script (see scripts/setup-keycloak-client.sh):
#   KEYCLOAK_URL=https://keycloak.example \
#   ADMIN_PASSWORD=your-admin-password    \
#   CLIENT_ID=portoser                    \
#   SERVICE_URL=http://portoser.example   \
#   ./scripts/setup-keycloak-client.sh
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_CLIENT_SECRET

# ------------------------------------------------------------------------------
# JWT Configuration
# ------------------------------------------------------------------------------
# CRITICAL: Required for production!
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=CHANGE_ME_GENERATE_STRONG_SECRET

# ------------------------------------------------------------------------------
# Vault (Optional)
# ------------------------------------------------------------------------------
# Get from: vault login
VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
